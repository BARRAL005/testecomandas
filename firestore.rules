rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }



    // Banco compartilhado do app PitStop Comandas
    // Permite sincronização em tempo real entre celular e PC para usuários logados.
    match /pitstop_shared/{docId} {
      allow read, write: if isSignedIn();
    }


    // Banco modular do app PitStop Comandas
    // Cada módulo salva separado para reduzir travamentos e evitar sobrescrita do app inteiro.
    match /pitstop_data/{docId} {
      allow read, write: if isSignedIn() && isValidId(docId);
    }

    // Users Collection Hardening
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Block query list-scraping of other user profiles
      
      allow create: if isSignedIn() 
        && isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data);
        
      allow update: if isSignedIn() 
        && isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.email == resource.data.email // Email is immutable
        && request.resource.data.createdAt == resource.data.createdAt; // createdAt is immutable

      allow delete: if false; // User accounts are immortal on client side
    }

    // Helper validation for User object
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt'])
        && data.keys().size() == 5
        && data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 150
        && data.role is string && (data.role == 'admin' || data.role == 'staff')
        && data.createdAt is timestamp;
    }
  }
}
