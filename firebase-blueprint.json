{
  "entities": {
    "users": {
      "title": "Users",
      "description": "User profiles for authenticated bar staff and managers",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Authentication UID"
        },
        "name": {
          "type": "string",
          "description": "User displayed screen name"
        },
        "email": {
          "type": "string",
          "description": "The verified email address of the user"
        },
        "photoURL": {
          "type": "string",
          "description": "Optional profile photo image URL"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "staff"],
          "description": "Role of the staff member"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The signup time of the profile"
        }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "The collection of staff/manager user profiles"
    }
  }
}
